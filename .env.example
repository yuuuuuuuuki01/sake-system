# Database
DATABASE_URL=postgresql://user:password@localhost:5432/syusen

# freee API
FREEE_ACCESS_TOKEN=your_access_token
FREEE_COMPANY_ID=12345
FREEE_DRY_RUN=false

# Logging
LOG_LEVEL=info

# Slack Notifications（任意）
SLACK_WEBHOOK_URL=

# Pipeline
SYUSEN_ANALYSIS_DIR=./references/analysis/current
SYUSEN_ANALYSIS_IMPORT_DIR=
SYUSEN_LEGACY_ROOT=./references/legacy-root
SYUSEN_WORK_DIR=./data
SYUSEN_PRIMARY_CODES=SHDEN,SHTOR,SHSYO,SHTKI,SHNKI
SYUSEN_SECONDARY_CODES=SHSUJ,SHTNSUJ,SHTEGATA,SHZEI,SHTAN,SHTANT
