{
  "name": "syusen-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "db:migrate": "kysely-ctl migrate",
    "db:rollback": "kysely-ctl rollback",
    "db:status": "kysely-ctl status",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "run:pipeline": "tsx src/jobs/pipeline.ts",
    "run:dashboard": "tsx src/ui/dashboard-prototype.ts",
    "sync:analysis-reference": "tsx src/tools/sync-analysis-reference.ts"
  },
  "dependencies": {
    "@types/pg": "^8.15.5",
    "dotenv": "^17.2.3",
    "iconv-lite": "^0.7.0",
    "kysely": "^0.28.8",
    "pg": "^8.16.3",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@types/iconv-lite": "^0.0.1",
    "@types/node": "^24.6.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "kysely-ctl": "^0.15.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
